#!/bin/bash
# bopp-tpm-refresh: Refreshes LUKS TPM2 enrollment for BoppOS

# 1. Identify the LUKS partition
LUKS_PART=$(lsblk -l -p -o NAME,FSTYPE | grep "crypto_LUKS" | head -n1 | awk '{print $1}')

if [[ -z "$LUKS_PART" ]]; then
    echo "❌ No LUKS encrypted partition detected. Skipping TPM refresh."
    exit 0
fi

echo "🔐 Encrypted partition found: $LUKS_PART"
echo "Your TPM2 PCRs likely changed during the rebase. We need to re-enroll."

# 2. Perform the enrollment
# Note: This will prompt the user for their existing recovery passphrase

# By default, systemd-cryptenroll binds to PCR 7 (Secure Boot).
# If Secure Boot is disabled, binding to PCR 7 might fail to unlock.
# Explicitly setting --tpm2-pcrs=7 ensures predictability.
sudo systemd-cryptenroll --tpm2-device=auto --tpm2-pcrs=7 --wipe-slot=tpm2 "$LUKS_PART"

if [[ $? -eq 0 ]]; then
    echo "✅ TPM2 successfully re-enrolled for BoppOS."
    
    # 3. Ensure /etc/crypttab is configured to use the TPM automatically
    if [ -f /etc/crypttab ] && ! grep -q "tpm2-device=auto" /etc/crypttab; then
        echo "🔧 Adding 'tpm2-device=auto' to /etc/crypttab..."
        # Safely append tpm2-device=auto to the options column
        sudo awk '/^luks-/ && !/tpm2-device=auto/ { if (NF==3) $4="tpm2-device=auto"; else if (NF>=4) $4=$4",tpm2-device=auto"; }1' /etc/crypttab | sudo tee /etc/crypttab.new > /dev/null
        sudo mv /etc/crypttab.new /etc/crypttab
    fi
else
    echo "⚠️ TPM2 enrollment failed. You may need to use your passphrase at next boot."
fi
