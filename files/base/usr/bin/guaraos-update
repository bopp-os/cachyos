#!/bin/bash
# guaraos-update — GuaraOS system update orchestrator
#
# With no arguments (or --all), delegates entirely to topgrade, which runs
# the full update pipeline as configured in:
#   ~/.config/topgrade.d/00-guaraos.toml  (seeded for all users via /etc/skel)
#
# Individual flags run specific steps. Most delegate to topgrade --only <step>
# so output and error handling are consistent. The --os flag is the exception:
# topgrade's [linux] bootc option only works on RPM-based immutable distros
# (Fedora/RHEL); CachyOS is detected as Distribution::Arch and always invokes
# paru/pacman. Calling bootc directly is therefore the only correct approach.
#
# Usage: guaraos-update [-o|-w|-f|-b|-d|-a|-h]

set -e

GREEN='\033[0;32m'
BLUE='\033[0;34m'
NC='\033[0m'

# ---------------------------------------------------------------------------
# Individual step functions
# ---------------------------------------------------------------------------

update_os() {
    echo -e "${GREEN}==> Updating OS image (bootc)...${NC}"
    sudo bootc upgrade
}

update_fw() {
    echo -e "${GREEN}==> Updating firmware (fwupd)...${NC}"
    topgrade --only firmware
}

update_flatpak() {
    echo -e "${GREEN}==> Updating Flatpaks...${NC}"
    topgrade --only flatpak
}

update_brew() {
    echo -e "${GREEN}==> Updating Homebrew...${NC}"
    topgrade --only brew_formula --only brew_cask
}

update_distrobox() {
    echo -e "${GREEN}==> Updating Distroboxes...${NC}"
    topgrade --only distrobox
}

# ---------------------------------------------------------------------------
# Help
# ---------------------------------------------------------------------------

show_help() {
    cat << 'EOF'
Usage: guaraos-update [OPTIONS]

GuaraOS system update orchestrator.

With no options, runs the full update pipeline via topgrade (OS image, firmware,
Flatpaks, Homebrew, and more), configured by ~/.config/topgrade.d/00-guaraos.toml.

Run 'topgrade' directly for the interactive, step-by-step experience.

Options:
  -o, --os         Update OS image (bootc upgrade, then reboot to apply)
  -w, --fw         Update firmware (fwupd, via topgrade)
  -f, --flatpak    Update Flatpaks — user + system (via topgrade)
  -b, --brew       Update Homebrew formulae and casks (via topgrade)
  -d, --distrobox  Upgrade all Distrobox containers (via topgrade)
  -a, --all        Run full update pipeline via topgrade (same as no args)
  -h, --help       Show this help message

Flags can be combined: guaraos-update -of   (OS + Flatpaks)
EOF
}

# ---------------------------------------------------------------------------
# Argument parsing
# ---------------------------------------------------------------------------

RUN_OS=false
RUN_FW=false
RUN_FLATPAK=false
RUN_BREW=false
RUN_DISTROBOX=false

if [ "$#" -eq 0 ]; then
    echo -e "${BLUE}Starting GuaraOS System Update...${NC}\n"
    exec topgrade
fi

while [[ "$#" -gt 0 ]]; do
    case $1 in
        -o|--os)        RUN_OS=true ;;
        -w|--fw)        RUN_FW=true ;;
        -f|--flatpak)   RUN_FLATPAK=true ;;
        -b|--brew)      RUN_BREW=true ;;
        -d|--distrobox) RUN_DISTROBOX=true ;;
        -a|--all)
            echo -e "${BLUE}Starting GuaraOS System Update...${NC}\n"
            exec topgrade
            ;;
        --help)
            show_help
            exit 0
            ;;
        -[!-]*)
            # Expand combined short flags: -of → -o -f
            flags="${1#-}"
            for (( i=0; i<${#flags}; i++ )); do
                case "${flags:$i:1}" in
                    o) RUN_OS=true ;;
                    w) RUN_FW=true ;;
                    f) RUN_FLATPAK=true ;;
                    b) RUN_BREW=true ;;
                    d) RUN_DISTROBOX=true ;;
                    a)
                        echo -e "${BLUE}Starting GuaraOS System Update...${NC}\n"
                        exec topgrade
                        ;;
                    h) show_help; exit 0 ;;
                    *) echo "Unknown flag: -${flags:$i:1}"; show_help; exit 1 ;;
                esac
            done
            ;;
        *) echo "Unknown parameter: $1"; show_help; exit 1 ;;
    esac
    shift
done

# ---------------------------------------------------------------------------
# Run selected steps
# ---------------------------------------------------------------------------

echo -e "${BLUE}Starting GuaraOS System Update...${NC}\n"

[ "$RUN_OS" = true ]        && update_os
[ "$RUN_FW" = true ]        && update_fw
[ "$RUN_FLATPAK" = true ]   && update_flatpak
[ "$RUN_BREW" = true ]      && update_brew
[ "$RUN_DISTROBOX" = true ] && update_distrobox

echo -e "\n${BLUE}GuaraOS update complete!${NC}"

if [ "$RUN_OS" = true ]; then
    echo -e "\nNote: If a new OS image was staged by bootc, reboot to apply it."
fi
