#!/bin/bash
# GuaraOS Optional Flatpak Installer
# Installs a curated list of Flatpaks sourced from Bazzite-DX

set -euo pipefail

echo "=========================================="
echo " GuaraOS Optional Flatpak Installer"
echo "=========================================="

BAZZITE_URL="https://raw.githubusercontent.com/ublue-os/bazzite-dx/refs/heads/main/system_files/etc/ublue-os/system_flatpaks"
GUARAOS_LIST="/usr/share/guaraos/guaraos-flatpaks.txt"
TMP_LIST=$(mktemp /tmp/guaraos_flatpaks.XXXXXX)
trap 'rm -f "$TMP_LIST"' EXIT

echo "[*] Fetching curated Flatpak list from Bazzite-DX..."
# Fetch the file, strip comments (#), remove empty lines, and save to temp file
curl -sSL "$BAZZITE_URL" | sed 's/#.*//' | grep -v '^\s*$' > "$TMP_LIST"

echo "[*] Merging GuaraOS custom Flatpaks..."
if [ -f "$GUARAOS_LIST" ]; then
    sed 's/#.*//' "$GUARAOS_LIST" | grep -v '^\s*$' >> "$TMP_LIST"
else
    echo "[!] Warning: Custom list $GUARAOS_LIST not found. Skipping."
fi

# Deduplicate and sort the merged list
sort -u -o "$TMP_LIST" "$TMP_LIST"

if [ ! -s "$TMP_LIST" ]; then
    echo "[!] Error: Failed to fetch or parse the Flatpak list."
    exit 1
fi

echo "[*] The curated list has been downloaded."
read -p "Would you like to review or edit the list before installing? [y/N]: " EDIT_CHOICE

if [[ "$EDIT_CHOICE" =~ ^[Yy]$ ]]; then
    ${EDITOR:-nano} "$TMP_LIST"
fi

# Read the (potentially edited) list into an array, stripping comments/blanks again just in case
mapfile -t FLATPAKS < <(sed 's/#.*//' "$TMP_LIST" | grep -v '^\s*$')

if [ ${#FLATPAKS[@]} -eq 0 ]; then
    echo "[*] No Flatpaks selected for installation. Exiting."
    exit 0
fi

echo "[*] Ensuring Flathub remote is configured..."
# Use system-wide flatpak if run as root, otherwise user-level
if [ "$(id -u)" -eq 0 ]; then
    FLATPAK_CMD="flatpak install --system -y flathub"
    flatpak remote-add --system --if-not-exists flathub https://flathub.org/repo/flathub.flatpakrepo
else
    FLATPAK_CMD="flatpak install --user -y flathub"
    flatpak remote-add --user --if-not-exists flathub https://flathub.org/repo/flathub.flatpakrepo
fi

echo "[*] Found ${#FLATPAKS[@]} Flatpaks to install."
echo "[*] Starting installation (this may take a while)..."

$FLATPAK_CMD "${FLATPAKS[@]}"

echo "[*] All optional Flatpaks have been installed successfully!"
